# ============================================================
# UNIKA STORE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA faça commit do .env.local
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Painel do Supabase: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Apenas para server-side / API routes (nunca exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY_AQUI

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://unikaloja.com.br

# ─── SEO / Analytics ──────────────────────────────────────────
# Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Email (Newsletter) ───────────────────────────────────────
# Resend ou Brevo para envio de newsletters
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
NEWSLETTER_FROM_EMAIL=newsletter@unikaloja.com.br

# ─── Admin ────────────────────────────────────────────────────
# Senha de proteção básica do painel admin (middleware)
ADMIN_SECRET=troque_esta_senha_forte_aqui
